NODE_ENV=test
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fox-finance-test

# Upload flow
UPLOAD_TOKEN_SECRET=replace-with-test-secret
FRONTEND_URL=http://localhost:5173

# AWS (test bucket name only - calls are mocked in integration tests)
S3_UPLOADS_BUCKET=test-uploads-bucket
S3_QUARANTINE_BUCKET=test-quarantine-bucket

# Malware scan tuning for tests
MALWARE_SCAN_DELAY_MS=10
MALWARE_SCAN_SENSITIVITY=low

# Integration test tuning
INTEGRATION_TEST_TIMEOUT_MS=60000
