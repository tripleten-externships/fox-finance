NODE_ENV=test
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fox-finance-test

# Upload flow
UPLOAD_TOKEN_SECRET=replace-with-test-secret
FRONTEND_URL=http://localhost:5173

# AWS (test bucket credentials)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-with-test-key
AWS_SECRET_ACCESS_KEY=replace-with-test-secret
S3_UPLOADS_BUCKET=replace-with-test-bucket
S3_QUARANTINE_BUCKET=replace-with-test-quarantine-bucket

# Malware scan tuning for tests
MALWARE_SCAN_DELAY_MS=10
MALWARE_SCAN_SENSITIVITY=low

# Integration test tuning
INTEGRATION_TEST_TIMEOUT_MS=60000
