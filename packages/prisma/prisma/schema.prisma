generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  ADMIN
  USER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum UploadStatus {
  COMPLETE
  INCOMPLETE
}

enum ScanStatus {
  PENDING
  SCANNING
  CLEAN
  THREAT_DETECTED
  FAILED
}

enum EmailStatus {
  SENT
  FAILED
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id                 String       @id
  email              String       @unique
  name               String?
  photoUrl           String?
  role               Role         @default(USER)
   uploadNotificationEnabled   Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  createdUploadLinks UploadLink[] @relation("CreatedLinks")
  updatedUploadLinks UploadLink[] @relation("UpdatedLinks")
}

// ============================================================================
// TODO: Add your models here
// Students should define: Client, UploadLink, DocumentRequest, Upload models
// ============================================================================

model EmailLog {
  id String @id @default(uuid()) @db.Uuid

  uploadLinkId String     @db.Uuid
  uploadLink   UploadLink @relation(fields: [uploadLinkId], references: [id], onDelete: Cascade)

  recipientEmail String
  subject        String?

  status       EmailStatus @default(SENT)
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  email                  String                  @unique
  firstName              String
  lastName               String
  company                String?
  phone                  String
  status                 Status                  @default(ACTIVE)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  id                     String                  @id @default(uuid()) @db.Uuid
  uploadLinks            UploadLink[]
  uploadNotificationLogs UploadNotificationLog[]

  @@index([phone])
  @@index([company])
  @@index([firstName])
  @@index([lastName])
}

model UploadLink {
  token            String            @unique
  expiresAt        DateTime
  isActive         Boolean           @default(false)
  createdById      String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  id               String            @id @default(uuid()) @db.Uuid
  clientId         String            @db.Uuid
  updatedById      String?
  documentRequests DocumentRequest[]
  uploads          Upload[]
  emailLogs        EmailLog[]
  UploadBatch      UploadBatch[]
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy        User              @relation("CreatedLinks", fields: [createdById], references: [id])
  updatedBy        User?             @relation("UpdatedLinks", fields: [updatedById], references: [id])

  @@index([clientId])
  @@index([isActive, expiresAt])
}

model DocumentRequest {
  instructions       String?
  status             UploadStatus        @default(INCOMPLETE)
  id                 String              @id @default(uuid()) @db.Uuid
  uploadLinkId       String              @db.Uuid
  uploadLink         UploadLink          @relation(fields: [uploadLinkId], references: [id], onDelete: Cascade)
  requestedDocuments RequestedDocument[]
  uploads            Upload[]
}

model RequestedDocument {
  description       String
  id                String           @id @default(uuid()) @db.Uuid
  documentRequestId String?          @db.Uuid
  documentTypeId    String
  documentRequest   DocumentRequest? @relation(fields: [documentRequestId], references: [id])
  documentType      DocumentType     @relation(fields: [documentTypeId], references: [id])

  @@index([documentTypeId])
}

model DocumentType {
  id                 String              @id @default(cuid())
  name               String              @unique
  description        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  requestedDocuments RequestedDocument[]
}

model Upload {
  fileName          String
  fileSize          Decimal
  s3Key             String
  s3Bucket          String
  uploadedAt        DateTime         @updatedAt
  metadata          Json
  id                String           @id @default(uuid()) @db.Uuid
  uploadLinkId      String           @db.Uuid
  documentRequestId String?          @db.Uuid
  uploadBatchId     String?          @db.Uuid
  fileType          String           @default("unknown")
  downloadCount     Int              @default(0)
  documentRequest   DocumentRequest? @relation(fields: [documentRequestId], references: [id])
  UploadBatch       UploadBatch?     @relation(fields: [uploadBatchId], references: [id])
  uploadLink        UploadLink       @relation(fields: [uploadLinkId], references: [id])
  scanStatus   ScanStatus @default(PENDING)
  scanResult   String?
  scannedAt    DateTime?

  @@index([uploadLinkId])
  @@index([fileName])
}

model UploadBatch {
  id            String     @id @default(uuid()) @db.Uuid
  uploadLinkId  String     @db.Uuid
  status        String
  totalFiles    Int
  uploadedFiles Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  uploads       Upload[]
  uploadLink    UploadLink @relation(fields: [uploadLinkId], references: [id])
}

// ============================================================================
// MODELS
// ============================================================================

enum NotificationFrequency {
  IMMEDIATE
  HOURLY
  DAILY
}

model UploadNotificationLog {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  sentAt    DateTime @default(now())
  uploadIds Json
  fileCount Int
  totalSize Decimal
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, sentAt])
}

